# Copy this file to .env and fill in real values.
# See the README's "Environment Variables" section for details on each one,
# where to get it, and what happens if it's left blank.

# --- Required ---
DB_URL=mongodb://localhost:27017/yelp-camp
SECRET=changeme-use-a-long-random-string
MAPBOX_TOKEN=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# --- Optional (AI features degrade gracefully if left blank) ---
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# --- Optional (defaults shown) ---
PORT=3000
NODE_ENV=development
