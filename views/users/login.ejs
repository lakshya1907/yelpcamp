<% layout('layouts/boilerplate') %>

<div class="yc-auth-wrap">
  <div class="yc-auth-card">
    <img class="yc-auth-img" src="https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=800&q=80" alt="campfire">
    <div class="yc-auth-body">
      <h2>Welcome back</h2>
      <p class="subtitle">Sign in to your YelpCamp account</p>
      <form action="/login" method="POST" class="validated-form" novalidate>
        <div class="yc-form-group">
          <label class="yc-label" for="username">Username</label>
          <input class="yc-input" type="text" id="username" name="username" autofocus required>
        </div>
        <div class="yc-form-group">
          <label class="yc-label" for="password">Password</label>
          <input class="yc-input" type="password" id="password" name="password" required>
        </div>
        <button class="btn-forest" type="submit" style="width:100%;justify-content:center;">Login</button>
      </form>
      <p style="text-align:center;margin-top:1.25rem;font-size:0.875rem;color:var(--stone);">
        No account? <a href="/register">Register here</a>
      </p>
    </div>
  </div>
</div>
