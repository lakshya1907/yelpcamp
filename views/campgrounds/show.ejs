<% layout('layouts/boilerplate') %>

<div class="yc-show-layout">
  <!-- LEFT: images + reviews -->
  <div>
    <!-- Carousel -->
    <div class="yc-carousel" id="yc-carousel">
      <% campground.images.forEach((img, i) => { %>
      <img src="<%= img.url %>" alt="" class="<%= i === 0 ? 'active' : '' %>">
      <% }) %>
      <% if (campground.images.length === 0) { %>
      <img src="https://res.cloudinary.com/douqbebwk/image/upload/v1600103881/YelpCamp/lz8jjv2gyynjil7lswf4.png" alt="" class="active">
      <% } %>
      <% if (campground.images.length > 1) { %>
      <button class="yc-carousel-btn prev" onclick="carouselMove(-1)">&#8592;</button>
      <button class="yc-carousel-btn next" onclick="carouselMove(1)">&#8594;</button>
      <% } %>
    </div>

    <!-- Reviews -->
    <div class="yc-reviews">
      <% if (currentUser) { %>
      <div class="yc-review-form">
        <h4>Leave a Review</h4>
        <form action="/campgrounds/<%= campground._id %>/reviews" method="POST" class="validated-form" novalidate>
          <div class="yc-form-group">
            <label class="yc-label">Your Rating</label>
            <div class="yc-star-input" id="star-input">
              <input type="radio" id="s5" name="review[rating]" value="5"><label for="s5">★</label>
              <input type="radio" id="s4" name="review[rating]" value="4"><label for="s4">★</label>
              <input type="radio" id="s3" name="review[rating]" value="3" checked><label for="s3">★</label>
              <input type="radio" id="s2" name="review[rating]" value="2"><label for="s2">★</label>
              <input type="radio" id="s1" name="review[rating]" value="1"><label for="s1">★</label>
            </div>
          </div>
          <div class="yc-form-group">
            <label class="yc-label" for="body">Your Experience</label>
            <textarea class="yc-input" name="review[body]" id="body" rows="3" required placeholder="What was it like?"></textarea>
          </div>
          <button class="btn-forest" type="submit">Submit Review</button>
        </form>
      </div>
      <% } %>

      <h3><%= campground.reviews.length %> Review<%= campground.reviews.length !== 1 ? 's' : '' %></h3>

      <% for (let review of campground.reviews) { %>
      <div class="yc-review-card">
        <div class="yc-review-card-header">
          <div>
            <p class="yc-reviewer"><%= review.author.username %></p>
            <div class="yc-stars">
              <% for (let i = 1; i <= 5; i++) { %>
              <span class="yc-star <%= i <= review.rating ? 'filled' : '' %>">★</span>
              <% } %>
            </div>
          </div>
          <% if (currentUser && review.author.equals(currentUser._id)) { %>
          <form action="/campgrounds/<%= campground._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
            <button class="btn-danger-ghost" type="submit">Delete</button>
          </form>
          <% } %>
        </div>
        <p class="yc-review-body"><%= review.body %></p>
      </div>
      <% } %>
    </div>
  </div>

  <!-- RIGHT: details + map -->
  <div>
    <div class="yc-detail-card">
      <div class="yc-detail-card-body">
        <h2><%= campground.title %></h2>
        <p class="desc"><%= campground.description %></p>
        <div class="yc-detail-meta">
          <div class="yc-detail-meta-row">📍 <strong><%= campground.location %></strong></div>
          <div class="yc-detail-meta-row">👤 Listed by <strong><%= campground.author ? campground.author.username : 'Unknown' %></strong></div>
        </div>
        <div class="yc-detail-price">$<%= campground.price %> <span>/ night</span></div>
        <% if (currentUser && campground.author && campground.author.equals(currentUser._id)) { %>
        <div class="yc-detail-actions">
          <a href="/campgrounds/<%= campground._id %>/edit" class="btn-ghost">Edit</a>
          <form action="/campgrounds/<%= campground._id %>?_method=DELETE" method="POST">
            <button class="btn-danger-ghost" type="submit">Delete</button>
          </form>
        </div>
        <% } %>
      </div>
    </div>

    <div class="yc-map-section">
      <div id="map"></div>
    </div>

    <div class="mt-2">
      <a href="/campgrounds" class="btn-ghost">← All Campgrounds</a>
    </div>
  </div>
</div>

<script>
  const mapToken = '<%-process.env.MAPBOX_TOKEN%>';
  const campground = <%- JSON.stringify(campground) %>

  // Carousel
  let idx = 0;
  function carouselMove(dir) {
    const imgs = document.querySelectorAll('#yc-carousel img');
    imgs[idx].classList.remove('active');
    idx = (idx + dir + imgs.length) % imgs.length;
    imgs[idx].classList.add('active');
  }
</script>
<script src="/javascripts/showPageMap.js"></script>
